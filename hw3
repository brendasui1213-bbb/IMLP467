import random

Max = 100
Min = 0
# ans = 45
ans = random.randint(1, 99)
count = 0

while True:
    print('請輸入', Min, '< ? <', Max, '範圍的數字：', end='')
    guess = int(input())
    count += 1
    
    if guess == ans:
        print('Bingo!')
        break
    elif guess > ans:
        Max = guess
        print('猜太大, 你猜了 %d 次' % (count))
    else:
        Min = guess
        print('猜太小, 你猜了 %d 次' % (count))
